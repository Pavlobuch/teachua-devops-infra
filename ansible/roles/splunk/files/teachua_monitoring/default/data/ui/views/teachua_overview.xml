<dashboard version="1.1">
  <label>TeachUA Overview</label>

  <row>
    <panel>
      <title>Total logs by container</title>
      <table>
        <search>
          <query>
            index=teachua_k8s
            | stats count by kubernetes.container_name
            | sort - count
          </query>
          <earliest>-24h@h</earliest>
          <latest>now</latest>
        </search>
      </table>
    </panel>

    <panel>
      <title>Errors and warnings</title>
      <single>
        <search>
          <query>
            index=teachua_k8s ("ERROR" OR "WARN" OR "Exception" OR "error")
            | stats count
          </query>
          <earliest>-24h@h</earliest>
          <latest>now</latest>
        </search>
      </single>
    </panel>
  </row>

  <row>
    <panel>
      <title>Logs over time</title>
      <chart>
        <search>
          <query>
            index=teachua_k8s
            | timechart count by kubernetes.container_name
          </query>
          <earliest>-24h@h</earliest>
          <latest>now</latest>
        </search>
        <option name="charting.chart">line</option>
      </chart>
    </panel>
  </row>
</dashboard>
